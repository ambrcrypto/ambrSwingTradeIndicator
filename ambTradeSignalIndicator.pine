//@version=6
indicator("AMB Dual MA Signal v1", overlay=true)

// ═══════════════════════════════════════════════════════════════════════
// INPUTS: Slow MA (Trend Filter – First Entry Trigger)
// ═══════════════════════════════════════════════════════════════════════
slowMA_tf   = input.timeframe("D",   "Slow MA TF",   group="Slow MA")
slowMA_type = input.string("SMA",    "Type",          options=["SMA","EMA"], group="Slow MA")
slowMA_len  = input.int(130,         "Length",        minval=1, group="Slow MA")
slowMA_show = input.bool(true,       "Show on Chart", group="Slow MA")

// ═══════════════════════════════════════════════════════════════════════
// INPUTS: Fast MA (Exit + Re-Entry Trigger)
// ═══════════════════════════════════════════════════════════════════════
fastMA_tf   = input.timeframe("D",   "Fast MA TF",   group="Fast MA")
useFastMA   = input.bool(true,       "Use Fast MA (false = Slow MA only)", group="Fast MA")
fastMA_type = input.string("SMA",    "Type",          options=["SMA","EMA"], group="Fast MA")
fastMA_len  = input.int(44,          "Length",        minval=1, group="Fast MA")

// ═══════════════════════════════════════════════════════════════════════
// INPUTS: Signal Control
// ═══════════════════════════════════════════════════════════════════════
allowLongs  = input.bool(true, "Allow Long Trades?",  group="Signal Control")
allowShorts = input.bool(true, "Allow Short Trades?", group="Signal Control")

// ═══════════════════════════════════════════════════════════════════════
// INPUTS: Backtest
// ═══════════════════════════════════════════════════════════════════════
backtest_enable = input.bool(false,  "Enable Backtesting",           group="Backtest")
leverageLong    = input.float(3.0,   "Leverage (Long)",  minval=0.1, step=0.1, group="Backtest")
leverageShort   = input.float(0.5,   "Leverage (Short)", minval=0.1, step=0.1, group="Backtest")
bt_start_year   = input.int(2021,    "Start Year",                   group="Backtest")
bt_start_month  = input.int(4,       "Start Month", minval=1, maxval=12, group="Backtest")
bt_start_day    = input.int(14,      "Start Day",   minval=1, maxval=31, group="Backtest")
bt_use_end_date = input.bool(false,  "Use End Date?",                group="Backtest")
bt_end_year     = input.int(2025,    "End Year",                     group="Backtest")
bt_end_month    = input.int(12,      "End Month",   minval=1, maxval=12, group="Backtest")
bt_end_day      = input.int(31,      "End Day",     minval=1, maxval=31, group="Backtest")
start_capital   = input.float(1000.0,"Start Capital", minval=1,      group="Backtest")

// ═══════════════════════════════════════════════════════════════════════
// INPUTS: Stop Loss
// ═══════════════════════════════════════════════════════════════════════
sl_enable    = input.bool(true,  "Enable Stop Loss",       group="Stop Loss")
sl_risk_pct  = input.float(6.0,  "Max Risk % per Trade", minval=0.1, step=0.1, group="Stop Loss")
// Long SL  = EP × (1 - sl_risk_pct / (100 × leverageLong))
// Short SL = EP × (1 + sl_risk_pct / (100 × leverageShort))

// ═══════════════════════════════════════════════════════════════════════
// INPUTS: Manual Entry Price
// Wenn Use Manual EP = true: eigener EP ersetzt Kerzenschluss für
// EP/SL-Anzeige im Chart und Backtest-Berechnung (eff. P/L, SL-Level).
// ═══════════════════════════════════════════════════════════════════════
use_manual_ep = input.bool(false, "Use Manual EP",                      group="Manual Entry")
manual_ep_val = input.float(0.0,  "Entry Price", minval=0.0, step=0.01, group="Manual Entry")

// ═══════════════════════════════════════════════════════════════════════
// INPUTS: Debug / Test Mode
// ═══════════════════════════════════════════════════════════════════════
test_mode = input.bool(false, "Test Mode (zeigt Signal-Subtyp)", group="Debug")

// ═══════════════════════════════════════════════════════════════════════
// HELPER FUNCTIONS
// ═══════════════════════════════════════════════════════════════════════
create_trade_label(pct) =>
    lbl_text  = (pct >= 0 ? "+" : "") + str.tostring(pct, "#.##") + "%"
    lbl_color = pct >= 0 ? color.green : color.red
    label.new(bar_index, close, text=lbl_text, yloc=yloc.abovebar, color=lbl_color,
              style=label.style_label_down, textcolor=color.white)

// ═══════════════════════════════════════════════════════════════════════
// CALCULATIONS
// ═══════════════════════════════════════════════════════════════════════
slowMA_calc  = slowMA_type == "SMA" ? ta.sma(close, slowMA_len) : ta.ema(close, slowMA_len)
slowMA_value = request.security(syminfo.tickerid, slowMA_tf, slowMA_calc, barmerge.gaps_off, barmerge.lookahead_off)

fastMA_calc  = fastMA_type == "SMA" ? ta.sma(close, fastMA_len) : ta.ema(close, fastMA_len)
fastMA_value = request.security(syminfo.tickerid, fastMA_tf, fastMA_calc, barmerge.gaps_off, barmerge.lookahead_off)

// ═══════════════════════════════════════════════════════════════════════
// STATE VARIABLES
// ═══════════════════════════════════════════════════════════════════════
var int   lastSignalDirection = 0      // -1=short, 0=none, 1=long
var bool  position_open       = false
var bool  longAboveFastMA     = false  // true = price has closed above Fast MA during current long
var bool  shortBelowFastMA    = false  // true = price has closed below Fast MA during current short
var float entry_price         = na     // eff_ep (manual oder close) – nur für visuelle EP/SL-Linie
var float ep_for_sl_trigger   = na     // immer close des Signal-Bars – für SL-Trigger-Berechnung
var line  current_entry_line  = na
var label current_entry_label = na
var line  sl_line_obj         = na
var label sl_label_obj        = na

// ═══════════════════════════════════════════════════════════════════════
// FAST MA STATE TRACKING
// Once price closes beyond Fast MA during an open trade, it stays tracked.
// Reset happens on new entry (state machine below).
// ═══════════════════════════════════════════════════════════════════════
if position_open and barstate.isconfirmed and useFastMA
    if lastSignalDirection == 1  and close > fastMA_value
        longAboveFastMA  := true
    if lastSignalDirection == -1 and close < fastMA_value
        shortBelowFastMA := true

// ═══════════════════════════════════════════════════════════════════════
// CROSSOVER / CROSSUNDER – globale Variablen (CW10002 Fix)
// Müssen auf jeder Bar ausgewertet werden – nie in Conditions einbetten
// ═══════════════════════════════════════════════════════════════════════
cross_above_slowMA  = ta.crossover(close, slowMA_value)
_cross_above_fastMA = ta.crossover(close, fastMA_value)   // always computed (CW10002 fix)
cross_above_fastMA  = useFastMA and _cross_above_fastMA
cross_below_slowMA  = ta.crossunder(close, slowMA_value)
_cross_below_fastMA = ta.crossunder(close, fastMA_value)  // always computed (CW10002 fix)
cross_below_fastMA  = useFastMA and _cross_below_fastMA

// ═══════════════════════════════════════════════════════════════════════
// SIGNAL CONDITIONS
// ═══════════════════════════════════════════════════════════════════════

// ── LONG ──────────────────────────────────────────────────────────────
// OL Entry: Slow MA crossed from below (first time long, no open position)
longEntry   = not position_open and lastSignalDirection != 1 and cross_above_slowMA

// OL Re-Entry: Fast MA crossed from below, still above Slow MA
longReentry = useFastMA and not position_open and lastSignalDirection == 1 and cross_above_fastMA and close > slowMA_value

// CL Exit A: Price was above Fast MA at some point → crosses back below Fast MA
exitLong_A  = useFastMA and position_open and lastSignalDirection == 1 and longAboveFastMA and cross_below_fastMA

// CL Exit B: Slow MA crossed downward – always triggers exit regardless of Fast MA state
exitLong_B  = position_open and lastSignalDirection == 1 and cross_below_slowMA

// CL Exit SL: Stop Loss – intrabar low touches/breaks SL level (no flip)
sl_long_level  = sl_enable and position_open and lastSignalDirection == 1  and not na(ep_for_sl_trigger) ? ep_for_sl_trigger * (1.0 - sl_risk_pct / (100.0 * leverageLong)) : float(na)
exitLong_SL    = not na(sl_long_level) and low <= sl_long_level

exitLong    = exitLong_A or exitLong_B or exitLong_SL

// ── SHORT ─────────────────────────────────────────────────────────────
// OS Entry: Slow MA crossed from above (first time short, no open position)
shortEntry   = not position_open and lastSignalDirection != -1 and cross_below_slowMA

// OS Re-Entry: Fast MA crossed from above, still below Slow MA
shortReentry = useFastMA and not position_open and lastSignalDirection == -1 and cross_below_fastMA and close < slowMA_value

// CS Exit A: Price was below Fast MA at some point → crosses back above Fast MA
exitShort_A  = useFastMA and position_open and lastSignalDirection == -1 and shortBelowFastMA and cross_above_fastMA

// CS Exit B: Slow MA crossed upward – always triggers exit regardless of Fast MA state
exitShort_B  = position_open and lastSignalDirection == -1 and cross_above_slowMA

// CS Exit SL: Stop Loss – intrabar high touches/breaks SL level (no flip)
sl_short_level = sl_enable and position_open and lastSignalDirection == -1 and not na(ep_for_sl_trigger) ? ep_for_sl_trigger * (1.0 + sl_risk_pct / (100.0 * leverageShort)) : float(na)
exitShort_SL   = not na(sl_short_level) and high >= sl_short_level

exitShort    = exitShort_A or exitShort_B or exitShort_SL

// ── FLIP: Exit + Entry auf gleicher Kerze via Slow MA Cross ───────────
// Flip to Short: Long exit + Slow MA gleichzeitig gekreuzt (auch bei SL-Exit erlaubt)
flipToShort  = exitLong  and cross_below_slowMA and allowShorts

// Flip to Long: Short exit + Slow MA gleichzeitig gekreuzt (auch bei SL-Exit erlaubt)
flipToLong   = exitShort and cross_above_slowMA and allowLongs

// ── FINALE SIGNALE ────────────────────────────────────────────────────
longSignal   = ((longEntry or longReentry) and allowLongs) or flipToLong
shortSignal  = ((shortEntry or shortReentry) and allowShorts) or flipToShort

// ═══════════════════════════════════════════════════════════════════════
// STATE MACHINE: Exits vor Entries (ermöglicht Flip auf gleicher Kerze)
// ═══════════════════════════════════════════════════════════════════════

// ── 1. EXITS: Position schliessen ────────────────────────────────────
if (exitLong or exitShort) and barstate.isconfirmed
    position_open       := false
    longAboveFastMA     := false
    shortBelowFastMA    := false
    entry_price         := na
    ep_for_sl_trigger   := na
    if not na(current_entry_line)
        line.delete(current_entry_line)
        current_entry_line := na
    if not na(current_entry_label)
        label.delete(current_entry_label)
        current_entry_label := na
    if not na(sl_line_obj)
        line.delete(sl_line_obj)
        sl_line_obj := na
    if not na(sl_label_obj)
        label.delete(sl_label_obj)
        sl_label_obj := na

// ── 2. ENTRIES: Position öffnen (inkl. Flip) ─────────────────────────
if longSignal and barstate.isconfirmed
    eff_ep              = use_manual_ep and manual_ep_val > 0 ? manual_ep_val : close
    lastSignalDirection := 1
    position_open       := true
    entry_price         := eff_ep          // visuelle EP/SL-Linie
    ep_for_sl_trigger   := close           // SL-Trigger immer auf Kerzenschluss-Basis
    longAboveFastMA     := close > fastMA_value
    if not na(current_entry_line)
        line.delete(current_entry_line)
    if not na(current_entry_label)
        label.delete(current_entry_label)
    if not na(sl_line_obj)
        line.delete(sl_line_obj)
        sl_line_obj := na
    if not na(sl_label_obj)
        label.delete(sl_label_obj)
        sl_label_obj := na
    current_entry_line  := line.new(bar_index, eff_ep, bar_index + 1, eff_ep,
                                    extend=extend.right, color=color.new(#0096FF, 0),
                                    style=line.style_dotted, width=1)
    current_entry_label := label.new(bar_index + 2, eff_ep,
                                     text=str.tostring(eff_ep, "#.##"),
                                     yloc=yloc.price, color=color.new(#0096FF, 0),
                                     style=label.style_label_left, textcolor=color.white)
    if sl_enable
        sl_lv = eff_ep * (1.0 - sl_risk_pct / (100.0 * leverageLong))
        sl_line_obj  := line.new(bar_index, sl_lv, bar_index + 1, sl_lv,
                                 extend=extend.right, color=color.new(color.red, 0),
                                 style=line.style_dotted, width=1)
        sl_label_obj := label.new(bar_index + 2, sl_lv,
                                  text=str.tostring(sl_lv, "#.##"),
                                  yloc=yloc.price, color=color.new(color.red, 0),
                                  style=label.style_label_left, textcolor=color.white)

else if shortSignal and barstate.isconfirmed
    eff_ep              = use_manual_ep and manual_ep_val > 0 ? manual_ep_val : close
    lastSignalDirection := -1
    position_open       := true
    entry_price         := eff_ep          // visuelle EP/SL-Linie
    ep_for_sl_trigger   := close           // SL-Trigger immer auf Kerzenschluss-Basis
    shortBelowFastMA    := close < fastMA_value
    if not na(current_entry_line)
        line.delete(current_entry_line)
    if not na(current_entry_label)
        label.delete(current_entry_label)
    if not na(sl_line_obj)
        line.delete(sl_line_obj)
        sl_line_obj := na
    if not na(sl_label_obj)
        label.delete(sl_label_obj)
        sl_label_obj := na
    current_entry_line  := line.new(bar_index, eff_ep, bar_index + 1, eff_ep,
                                    extend=extend.right, color=color.new(#0096FF, 0),
                                    style=line.style_dotted, width=1)
    current_entry_label := label.new(bar_index + 2, eff_ep,
                                     text=str.tostring(eff_ep, "#.##"),
                                     yloc=yloc.price, color=color.new(#0096FF, 0),
                                     style=label.style_label_left, textcolor=color.white)
    if sl_enable
        sl_lv = eff_ep * (1.0 + sl_risk_pct / (100.0 * leverageShort))
        sl_line_obj  := line.new(bar_index, sl_lv, bar_index + 1, sl_lv,
                                 extend=extend.right, color=color.new(color.red, 0),
                                 style=line.style_dotted, width=1)
        sl_label_obj := label.new(bar_index + 2, sl_lv,
                                  text=str.tostring(sl_lv, "#.##"),
                                  yloc=yloc.price, color=color.new(color.red, 0),
                                  style=label.style_label_left, textcolor=color.white)

// ── EP/SL Label auf rechten Rand aktualisieren (simuliert Price Label) ──
if position_open and not na(current_entry_label)
    label.set_x(current_entry_label, bar_index + 2)
if position_open and not na(entry_price)
    if sl_enable
        sl_lv_cur = lastSignalDirection == 1 ? entry_price * (1.0 - sl_risk_pct / (100.0 * leverageLong)) : entry_price * (1.0 + sl_risk_pct / (100.0 * leverageShort))
        if na(sl_line_obj)
            sl_line_obj := line.new(bar_index, sl_lv_cur, bar_index + 1, sl_lv_cur,
                                    extend=extend.right, color=color.new(color.red, 0),
                                    style=line.style_dotted, width=1)
        if na(sl_label_obj)
            sl_label_obj := label.new(bar_index + 2, sl_lv_cur,
                                      text=str.tostring(sl_lv_cur, "#.##"),
                                      yloc=yloc.price, color=color.new(color.red, 0),
                                      style=label.style_label_left, textcolor=color.white)
        else
            label.set_x(sl_label_obj, bar_index + 2)
    else
        if not na(sl_line_obj)
            line.delete(sl_line_obj)
            sl_line_obj := na
        if not na(sl_label_obj)
            label.delete(sl_label_obj)
            sl_label_obj := na

// ═══════════════════════════════════════════════════════════════════════
// BACKTEST SIMULATION
// ═══════════════════════════════════════════════════════════════════════
start_ts   = timestamp(bt_start_year, bt_start_month, bt_start_day, 0, 0)
end_ts     = bt_use_end_date ? timestamp(bt_end_year, bt_end_month, bt_end_day, 23, 59) : na
future_ts  = timestamp(2099, 12, 31, 23, 59)
sim_end_ts = na(end_ts) ? future_ts : end_ts
in_window  = time >= start_ts and time <= sim_end_ts

var bool    bt_position_open   = false
var int     bt_position_type   = 0
var float   bt_entry_price     = na
var int     trades             = 0
var table   stats_tbl          = table.new(position.bottom_left, 4, 4)
var bool    window_initialized = false
var float[] trade_percs        = array.new_float()
var label   live_trade_lbl     = na

if backtest_enable
    trade_pct = 0.0

    if in_window and not window_initialized
        bt_position_open   := false
        bt_position_type   := 0
        bt_entry_price     := na
        trades             := 0
        array.clear(trade_percs)
        window_initialized := true

    if not in_window
        window_initialized := false

    if in_window
        // ── 1. EXITS first (mirrors main state machine – enables flip on same bar) ──
        if exitLong and bt_position_open and bt_position_type == 1
            if exitLong_SL
                trade_pct := -sl_risk_pct
            else
                trade_pct := ((close - bt_entry_price) / bt_entry_price * 100.0) * leverageLong
            array.push(trade_percs, trade_pct)
            trades += 1
            create_trade_label(trade_pct)
            bt_position_open := false
            bt_position_type := 0
            bt_entry_price   := na

        if exitShort and bt_position_open and bt_position_type == -1
            if exitShort_SL
                trade_pct := -sl_risk_pct
            else
                trade_pct := ((bt_entry_price - close) / bt_entry_price * 100.0) * leverageShort
            array.push(trade_percs, trade_pct)
            trades += 1
            create_trade_label(trade_pct)
            bt_position_open := false
            bt_position_type := 0
            bt_entry_price   := na

        // ── 2. ENTRIES second (position is now free after any exit/flip) ──────────
        if longSignal and not bt_position_open
            bt_entry_price   := close   // Backtest immer mit Kerzenschluss (manual_ep nur für Chart-Anzeige)
            bt_position_type := 1
            bt_position_open := true

        if shortSignal and not bt_position_open
            bt_entry_price   := close   // Backtest immer mit Kerzenschluss (manual_ep nur für Chart-Anzeige)
            bt_position_type := -1
            bt_position_open := true

    if not in_window and not na(sim_end_ts) and time > sim_end_ts and bt_position_open
        if bt_position_type == 1
            trade_pct := ((close - bt_entry_price) / bt_entry_price * 100.0) * leverageLong
        else
            trade_pct := ((bt_entry_price - close) / bt_entry_price * 100.0) * leverageShort
        array.push(trade_percs, trade_pct)
        trades += 1
        create_trade_label(trade_pct)
        bt_position_open := false
        bt_position_type := 0
        bt_entry_price   := na

// ═══════════════════════════════════════════════════════════════════════
// PERFORMANCE METRICS
// ═══════════════════════════════════════════════════════════════════════

// Unrealized P/L der offenen Position – immer mit theoretischem bt_entry_price (Kerzenschluss)
// Wird für end_capital / P/L-Statistik verwendet → ändert sich NIE durch Manual EP
unrealized_pct = 0.0
if backtest_enable and not bt_use_end_date and bt_position_open
    if bt_position_type == 1
        unrealized_pct := ((close - bt_entry_price) / bt_entry_price * 100.0) * leverageLong
    else if bt_position_type == -1
        unrealized_pct := ((bt_entry_price - close) / bt_entry_price * 100.0) * leverageShort

// Anzeige-Unrealized: nutzt Manual EP wenn aktiv – NUR für "End:"-Feld und Live-Label
// Zeigt die echte P/L des aktuellen Trades basierend auf dem realen Einstiegspreis
display_unrealized = unrealized_pct
if backtest_enable and not bt_use_end_date and bt_position_open and use_manual_ep and manual_ep_val > 0
    if bt_position_type == 1
        display_unrealized := ((close - manual_ep_val) / manual_ep_val * 100.0) * leverageLong
    else if bt_position_type == -1
        display_unrealized := ((manual_ep_val - close) / manual_ep_val * 100.0) * leverageShort

end_capital = start_capital
if array.size(trade_percs) > 0
    for i = 0 to array.size(trade_percs) - 1
        end_capital := end_capital * (1 + array.get(trade_percs, i) / 100.0)
if unrealized_pct != 0.0
    end_capital := end_capital * (1 + unrealized_pct / 100.0)

pl_curr = end_capital - start_capital
pl_pct  = start_capital == 0 ? 0.0 : (pl_curr / start_capital) * 100.0

computed_max_win  = float(na)
computed_max_loss = float(na)
if array.size(trade_percs) > 0
    computed_max_win  := array.get(trade_percs, 0)
    computed_max_loss := array.get(trade_percs, 0)
    for i = 0 to array.size(trade_percs) - 1
        v = array.get(trade_percs, i)
        computed_max_win  := math.max(computed_max_win, v)
        computed_max_loss := math.min(computed_max_loss, v)

winning_trades = 0
losing_trades  = 0
if array.size(trade_percs) > 0
    for i = 0 to array.size(trade_percs) - 1
        if array.get(trade_percs, i) >= 0
            winning_trades += 1
        else
            losing_trades  += 1

win_pct = trades == 0 ? 0.0 : (winning_trades / trades) * 100.0

// ── Extended metrics ─────────────────────────────────────────────────
sum_wins   = 0.0
sum_losses = 0.0
if array.size(trade_percs) > 0
    for i = 0 to array.size(trade_percs) - 1
        v = array.get(trade_percs, i)
        if v >= 0
            sum_wins   += v
        else
            sum_losses += v

avg_win_pct   = winning_trades > 0 ? sum_wins   / winning_trades     : 0.0
avg_loss_pct  = losing_trades  > 0 ? sum_losses / losing_trades      : 0.0
profit_factor = sum_losses < 0     ? sum_wins / math.abs(sum_losses) : float(na)
expectancy    = (win_pct / 100.0 * avg_win_pct) + ((1.0 - win_pct / 100.0) * avg_loss_pct)

max_dd = 0.0
if array.size(trade_percs) > 0
    run_cap  = start_capital
    peak_cap = start_capital
    for i = 0 to array.size(trade_percs) - 1
        run_cap  := run_cap * (1.0 + array.get(trade_percs, i) / 100.0)
        if run_cap > peak_cap
            peak_cap := run_cap
        dd_val = (peak_cap - run_cap) / peak_cap * 100.0
        if dd_val > max_dd
            max_dd := dd_val

// Live-Label für offene Position auf aktueller Kerze
if backtest_enable and not bt_use_end_date
    if not na(live_trade_lbl)
        label.delete(live_trade_lbl)
        live_trade_lbl := na
    if bt_position_open
        live_lbl_text  = (display_unrealized >= 0 ? "+" : "") + str.tostring(display_unrealized, "#.##") + "%"
        live_lbl_color = display_unrealized >= 0 ? color.green : color.red
        live_trade_lbl := label.new(bar_index, close,
                                    text=live_lbl_text,
                                    yloc=yloc.abovebar,
                                    color=live_lbl_color,
                                    style=label.style_label_down,
                                    textcolor=color.white)

// ═══════════════════════════════════════════════════════════════════════
// DISPLAY: Stats table (fixed – no recreation on every bar)
// ═══════════════════════════════════════════════════════════════════════
if backtest_enable
    table.clear(stats_tbl, 0, 0, 3, 3)
    start_date_str = str.tostring(bt_start_year) + "-" +
                     (bt_start_month < 10 ? "0" : "") + str.tostring(bt_start_month) + "-" +
                     (bt_start_day   < 10 ? "0" : "") + str.tostring(bt_start_day)
    end_date_str   = bt_use_end_date ?
                     (str.tostring(bt_end_year) + "-" +
                      (bt_end_month < 10 ? "0" : "") + str.tostring(bt_end_month) + "-" +
                      (bt_end_day   < 10 ? "0" : "") + str.tostring(bt_end_day)) :
                     (bt_position_open ?
                      (bt_position_type == 1 ? "LONG " : "SHORT ") +
                      (display_unrealized >= 0 ? "+" : "") + str.tostring(display_unrealized, "#.##") + "%" :
                      "live")
    live_col = not bt_use_end_date and bt_position_open ?
               (display_unrealized >= 0 ? color.new(#00e676, 0) : color.new(#ff5252, 0)) :
               color.white

    bg      = color.new(#1e2130, 0)
    pl_col  = pl_pct     >= 0 ? color.new(#00e676, 0) : color.new(#ff5252, 0)
    exp_col = expectancy >= 0 ? color.new(#00e676, 0) : color.new(#ff5252, 0)

    // Row 0: Period + Trades
    table.cell(stats_tbl, 0, 0, "Start: " + start_date_str,                      bgcolor=bg, text_color=color.white, text_size=size.small)
    table.cell(stats_tbl, 1, 0, "End: "   + end_date_str,                        bgcolor=bg, text_color=live_col,      text_size=size.small)
    table.cell(stats_tbl, 2, 0, "Cap: $"  + str.tostring(start_capital, "#.##"), bgcolor=bg, text_color=color.white, text_size=size.small)
    table.cell(stats_tbl, 3, 0, "Trades: " + str.tostring(trades),               bgcolor=bg, text_color=color.white, text_size=size.small)

    // Row 1: P/L
    table.cell(stats_tbl, 0, 1, "P/L: "  + str.tostring(pl_pct,      "#.##") + "%", bgcolor=bg, text_color=pl_col,       text_size=size.small)
    table.cell(stats_tbl, 1, 1, "P/L: $" + str.tostring(pl_curr,     "#.##"),        bgcolor=bg, text_color=color.white, text_size=size.small)
    table.cell(stats_tbl, 2, 1, "End: $" + str.tostring(end_capital, "#.##"),        bgcolor=bg, text_color=color.white, text_size=size.small)
    table.cell(stats_tbl, 3, 1, "Win: "  + str.tostring(win_pct,     "#.##") + "%",  bgcolor=bg, text_color=color.white, text_size=size.small)

    // Row 2: Risk metrics
    table.cell(stats_tbl, 0, 2, "MaxW: "  + (array.size(trade_percs) > 0 ? str.tostring(computed_max_win,  "#.##") + "%" : "n/a"), bgcolor=bg, text_color=color.white, text_size=size.small)
    table.cell(stats_tbl, 1, 2, "MaxL: "  + (array.size(trade_percs) > 0 ? str.tostring(computed_max_loss, "#.##") + "%" : "n/a"), bgcolor=bg, text_color=color.white, text_size=size.small)
    table.cell(stats_tbl, 2, 2, "MaxDD: " + (array.size(trade_percs) > 0 ? str.tostring(max_dd, "#.##") + "%"            : "n/a"), bgcolor=bg, text_color=color.white, text_size=size.small)
    table.cell(stats_tbl, 3, 2, "PF: "    + (na(profit_factor) ? "n/a" : str.tostring(profit_factor, "#.##")),               bgcolor=bg, text_color=color.white, text_size=size.small)

    // Row 3: Expectancy
    table.cell(stats_tbl, 0, 3, "AvgW: " + (winning_trades > 0 ? str.tostring(avg_win_pct,  "#.##") + "%" : "n/a"), bgcolor=bg, text_color=color.white, text_size=size.small)
    table.cell(stats_tbl, 1, 3, "AvgL: " + (losing_trades  > 0 ? str.tostring(avg_loss_pct, "#.##") + "%" : "n/a"), bgcolor=bg, text_color=color.white, text_size=size.small)
    table.cell(stats_tbl, 2, 3, "Exp: "  + str.tostring(expectancy, "#.##") + "%",                                   bgcolor=bg, text_color=exp_col,      text_size=size.small)
    table.cell(stats_tbl, 3, 3, "L:" + str.tostring(leverageLong, "#.##") + "x S:" + str.tostring(leverageShort, "#.##") + "x SL:" + str.tostring(sl_risk_pct, "#.#") + "% MA:" + str.tostring(slowMA_len) + "/" + str.tostring(fastMA_len), bgcolor=bg, text_color=color.white, text_size=size.small)

// ═══════════════════════════════════════════════════════════════════════
// VISUALIZATION
// ═══════════════════════════════════════════════════════════════════════
plot(slowMA_show ? slowMA_value : na, title="Slow MA (130)", color=color.new(color.yellow, 0), linewidth=2)
plot(useFastMA ? fastMA_value : na, title="Fast MA (44)", color=color.new(color.blue, 0), linewidth=2)

bgcolor(backtest_enable and in_window ? color.new(color.yellow, 90) : na)

show_signal = (not backtest_enable or in_window) and barstate.isconfirmed

// Long-Signale unter der Kerze (Dreieck zeigt nach oben), Short-Signale über der Kerze (Dreieck zeigt nach unten)
plotshape(show_signal and (longEntry or flipToLong),    title="OL Entry",    location=location.belowbar,
          style=shape.triangleup,   size=size.tiny,  color=color.new(color.green, 0), text="OL")
plotshape(show_signal and longReentry,                  title="OL Re-Entry", location=location.belowbar,
          style=shape.triangleup,   size=size.tiny,  color=color.new(color.green, 0), text="RL")
plotshape(show_signal and (shortEntry or flipToShort),  title="OS Entry",    location=location.abovebar,
          style=shape.triangledown, size=size.tiny,  color=color.new(color.red,   0), text="OS")
plotshape(show_signal and shortReentry,                 title="OS Re-Entry", location=location.abovebar,
          style=shape.triangledown, size=size.tiny,  color=color.new(color.red,   0), text="RS")
plotshape(show_signal and exitLong  and not exitLong_SL,  title="Close Long",  location=location.belowbar,
          style=shape.cross,        size=size.tiny,  color=color.new(color.orange, 0), text="CL")
plotshape(show_signal and exitShort and not exitShort_SL, title="Close Short", location=location.abovebar,
          style=shape.cross,        size=size.tiny,  color=color.new(color.orange, 0), text="CS")
plotshape(show_signal and exitLong_SL,                  title="SL Long",     location=location.belowbar,
          style=shape.xcross,       size=size.tiny,  color=color.new(color.red,    0), text="SL")
plotshape(show_signal and exitShort_SL,                 title="SL Short",    location=location.abovebar,
          style=shape.xcross,       size=size.tiny,  color=color.new(color.red,    0), text="SL")

// Test Mode: TC-Gruppen-ID als Label (gegenüberliegende Seite zum Signal)
if test_mode and show_signal
    lbl_bg  = color.new(color.gray, 30)
    lbl_txt = color.white
    lbl_sz  = size.small
    if longEntry
        label.new(bar_index, close, "A01", yloc=yloc.abovebar, color=lbl_bg, style=label.style_label_down, textcolor=lbl_txt, size=lbl_sz)
    if longReentry
        label.new(bar_index, close, "B01", yloc=yloc.abovebar, color=lbl_bg, style=label.style_label_down, textcolor=lbl_txt, size=lbl_sz)
    if flipToLong
        label.new(bar_index, close, "FL",  yloc=yloc.abovebar, color=lbl_bg, style=label.style_label_down, textcolor=lbl_txt, size=lbl_sz)
    if exitLong_A
        label.new(bar_index, close, "C01", yloc=yloc.abovebar, color=lbl_bg, style=label.style_label_down, textcolor=lbl_txt, size=lbl_sz)
    if exitLong_B
        label.new(bar_index, close, "C02", yloc=yloc.abovebar, color=lbl_bg, style=label.style_label_down, textcolor=lbl_txt, size=lbl_sz)
    if shortEntry
        label.new(bar_index, close, "A03", yloc=yloc.belowbar, color=lbl_bg, style=label.style_label_up,   textcolor=lbl_txt, size=lbl_sz)
    if shortReentry
        label.new(bar_index, close, "B04", yloc=yloc.belowbar, color=lbl_bg, style=label.style_label_up,   textcolor=lbl_txt, size=lbl_sz)
    if flipToShort
        label.new(bar_index, close, "FS",  yloc=yloc.belowbar, color=lbl_bg, style=label.style_label_up,   textcolor=lbl_txt, size=lbl_sz)
    if exitShort_A
        label.new(bar_index, close, "C04", yloc=yloc.belowbar, color=lbl_bg, style=label.style_label_up,   textcolor=lbl_txt, size=lbl_sz)
    if exitShort_B
        label.new(bar_index, close, "C05", yloc=yloc.belowbar, color=lbl_bg, style=label.style_label_up,   textcolor=lbl_txt, size=lbl_sz)

// ═══════════════════════════════════════════════════════════════════════
// ALERTS
// ═══════════════════════════════════════════════════════════════════════
alertcondition(longSignal  and barstate.isconfirmed, title="AMB ENTER LONG",  message="AMB ENTER LONG on {{ticker}}")
alertcondition(shortSignal and barstate.isconfirmed, title="AMB ENTER SHORT", message="AMB ENTER SHORT on {{ticker}}")
alertcondition(exitLong    and barstate.isconfirmed, title="AMB EXIT LONG",   message="AMB EXIT LONG on {{ticker}}")
alertcondition(exitShort   and barstate.isconfirmed, title="AMB EXIT SHORT",  message="AMB EXIT SHORT on {{ticker}}")
